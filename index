<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="ARMYTEK links — official website and social media.">
  <title>ARMYTEK — Links</title>
  <style>
    :root {
      --yellow: #ffcc00;
      --black: #000000;
      --bg: #070707;
      --card: rgba(18, 18, 18, 0.86);
      --text: #f7f7f7;
      --muted: #d8d8d8;
      --shadow-soft: 0 22px 60px rgba(0, 0, 0, 0.48);
      --shadow-button: 0 14px 28px rgba(0, 0, 0, 0.34);
    }

    * { box-sizing: border-box; }

    html {
      min-height: 100%;
      background: var(--bg);
    }

    body {
      min-height: 100svh;
      margin: 0;
      font-family: "Muller", "Arial", "Helvetica Neue", sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top, rgba(255, 204, 0, 0.18), transparent 34rem),
        linear-gradient(180deg, #171717 0%, #111111 54%, #050505 100%);
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background-image:
        linear-gradient(rgba(255, 255, 255, 0.045) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.045) 1px, transparent 1px);
      background-size: 32px 32px;
      mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.45), transparent 70%);
    }

    .page {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100svh;
      padding: 28px 16px;
    }

    .profile-card {
      width: min(100%, 480px);
      padding: 28px 18px 22px;
      text-align: center;
      background: var(--card);
      border: 1px solid rgba(255, 255, 255, 0.10);
      border-radius: 28px;
      box-shadow: var(--shadow-soft);
      backdrop-filter: blur(14px);
    }

    .avatar-wrap {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 128px;
      height: 128px;
      aspect-ratio: 1 / 1;
      padding: 5px;
      margin-bottom: 18px;
      background: var(--yellow);
      border-radius: 50%;
      box-shadow: 0 16px 34px rgba(255, 204, 0, 0.34);
    }

    .avatar {
      display: block;
      width: 100%;
      height: 100%;
      aspect-ratio: 1 / 1;
      object-fit: cover;
      border: 4px solid var(--text);
      border-radius: 50%;
      overflow: hidden;
      background: var(--black);
    }

    .brand-name {
      margin: 0;
      color: var(--text);
      font-size: clamp(2.15rem, 10vw, 3.35rem);
      line-height: 0.95;
      font-weight: 900;
      letter-spacing: 0.055em;
    }

    .description {
      max-width: 390px;
      margin: 14px auto 24px;
      color: var(--muted);
      font-size: 1rem;
      line-height: 1.55;
    }

    .links {
      display: grid;
      gap: 12px;
      width: 100%;
    }

    .button-link {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      min-height: 58px;
      padding: 15px 18px;
      border: 2px solid var(--black);
      border-radius: 20px;
      color: var(--text);
      background: var(--black);
      box-shadow: var(--shadow-button);
      font-size: 1.02rem;
      font-weight: 800;
      line-height: 1.2;
      text-decoration: none;
      transition: transform 180ms ease, box-shadow 180ms ease, background-color 180ms ease, color 180ms ease;
    }

    .button-link:hover {
      transform: translateY(-3px);
      box-shadow: 0 18px 30px rgba(0, 0, 0, 0.42);
    }

    .button-link:active { transform: translateY(-1px); }

    .button-link:focus-visible {
      outline: 3px solid var(--yellow);
      outline-offset: 4px;
    }

    .button-link.official {
      color: var(--black);
      background: var(--yellow);
      text-shadow: none;
    }

    .button-link.official:hover { background: #ffd83d; }

    .button-link.social,
    .button-link.website-bottom {
      gap: 12px;
      justify-content: flex-start;
      padding-inline: 16px 22px;
      text-align: left;
    }

    .button-link.social .label,
    .button-link.website-bottom .label {
      flex: 1;
      text-align: center;
      transform: translateX(-22px);
    }

    .icon-badge {
      display: inline-flex;
      flex: 0 0 auto;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      border-radius: 15px;
      color: var(--black);
      background: var(--yellow);
    }

    .button-link.official .icon-badge {
      color: var(--yellow);
      background: var(--black);
    }

    .icon-badge svg {
      display: block;
      width: 23px;
      height: 23px;
      fill: currentColor;
    }

    .tagline {
      margin: 26px 0 0;
      color: var(--text);
      font-size: 0.98rem;
      font-weight: 900;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    @media (min-width: 520px) {
      .page { padding: 42px 24px; }
      .profile-card { padding: 34px 28px 26px; }
      .button-link { min-height: 62px; }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        scroll-behavior: auto !important;
        transition-duration: 0.01ms !important;
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
      }

      .button-link:hover { transform: none; }
    }
  </style>
</head>
<body>
  <main class="page">
    <section class="profile-card" aria-labelledby="brand-title">
      <div class="avatar-wrap">
        <svg class="avatar" viewBox="0 0 428 426" width="128" height="128" aria-hidden="true" focusable="false">
          <rect width="428" height="426" fill="#000000"/>
          <path fill="#ffcc00" d="M 53 215 L 77 251 L 108 283 L 156 317 L 187 332 L 219 343 L 251 350 L 284 353 L 294 351 L 299 345 L 321 292 L 330 249 L 332 197 L 326 152 L 307 95 L 295 74 L 271 72 L 232 78 L 198 88 L 164 103 L 137 119 L 105 144 L 85 164 L 57 201 Z"/>
        </svg>
      </div>

      <h1 class="brand-name" id="brand-title">ARMYTEK</h1>

      <p class="description">
        Manufacturer of high-tech flashlights, chargers and accessories. We focus on quality and reliability.
      </p>

      <nav class="links" aria-label="ARMYTEK links">
        <a class="button-link social" href="https://www.instagram.com/armytek_usa/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <span class="icon-badge" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="img">
              <path d="M7.75 2h8.5A5.76 5.76 0 0 1 22 7.75v8.5A5.76 5.76 0 0 1 16.25 22h-8.5A5.76 5.76 0 0 1 2 16.25v-8.5A5.76 5.76 0 0 1 7.75 2Zm0 2A3.75 3.75 0 0 0 4 7.75v8.5A3.75 3.75 0 0 0 7.75 20h8.5A3.75 3.75 0 0 0 20 16.25v-8.5A3.75 3.75 0 0 0 16.25 4h-8.5Zm8.75 2.1a1.4 1.4 0 1 1 0 2.8 1.4 1.4 0 0 1 0-2.8ZM12 7.25A4.75 4.75 0 1 1 12 16.75 4.75 4.75 0 0 1 12 7.25Zm0 2A2.75 2.75 0 1 0 12 14.75 2.75 2.75 0 0 0 12 9.25Z"/>
            </svg>
          </span>
          <span class="label">Instagram</span>
        </a>

        <a class="button-link social" href="https://www.facebook.com/storearmytek " target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          <span class="icon-badge" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="img">
              <path d="M13.9 22v-8.08h2.71l.41-3.15H13.9V8.76c0-.91.25-1.53 1.56-1.53h1.67V4.41A22.4 22.4 0 0 0 14.7 4c-2.41 0-4.06 1.47-4.06 4.17v2.6H7.91v3.15h2.73V22h3.26Z"/>
            </svg>
          </span>
          <span class="label">Facebook</span>
        </a>

     
        <a class="button-link official website-bottom" href="armytekstore.com" target="_blank" rel="noopener noreferrer" aria-label="Official website">
          <span class="icon-badge" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="img">
              <path d="M14 3h7v7h-2V6.41l-9.29 9.3-1.42-1.42 9.3-9.29H14V3ZM5 5h6v2H7v10h10v-4h2v6H5V5Z"/>
            </svg>
          </span>
          <span class="label">official website: armytekstore.com</span>
        </a>
      </nav>

      <p class="tagline">Built to exceed</p>
    </section>
  </main>
</body>
</html>
